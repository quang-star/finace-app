<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Background card shape with subtle glow gradient -->
    <path
        android:pathData="M 15 5 C 5 5, 5 5, 5 15 L 5 85 C 5 95, 5 95, 15 95 L 85 95 C 95 95, 95 95, 95 85 L 95 15 C 95 5, 95 5, 85 5 Z"
        android:fillColor="#161B2A"/>

    <!-- Glowing rounded outer border -->
    <path
        android:pathData="M 15 5 C 5 5, 5 5, 5 15 L 5 85 C 5 95, 5 95, 15 95 L 85 95 C 95 95, 95 95, 95 85 L 95 15 C 95 5, 95 5, 85 5 Z"
        android:strokeWidth="1.5"
        android:strokeColor="#3B82F6"/>

    <!-- The stylized letter 'S' path in the center -->
    <!-- Drawn carefully with cubic Bezier curves to look extremely premium and smooth -->
    <path
        android:pathData="M 70 32
                  C 70 24, 60 20, 50 20
                  C 35 20, 30 28, 30 35
                  C 30 46, 70 42, 70 58
                  C 70 70, 60 78, 48 78
                  C 30 78, 28 68, 28 62
                  M 30 65 L 30 62 L 34 62 L 34 65 Z"
        android:strokeWidth="8.5"
        android:strokeColor="#3B82F6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>

    <!-- Inside glow curve for 'S' -->
    <path
        android:pathData="M 68 32
                  C 68 26, 60 22, 50 22
                  C 37 22, 32 29, 32 35
                  C 32 44, 68 40, 68 58
                  C 68 68, 60 76, 48 76
                  C 32 76, 30 68, 30 62"
        android:strokeWidth="3.5"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>

    <!-- Sparkle accent top right -->
    <path
        android:pathData="M 78 16 L 82 22 L 88 16 L 82 10 Z"
        android:fillColor="#FFFFFF"/>

    <!-- Sparkle accent bottom left -->
    <path
        android:pathData="M 12 78 L 16 84 L 22 78 L 16 72 Z"
        android:fillColor="#3B82F6"/>
</vector>
