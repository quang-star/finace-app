<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Screen Background Image (Keyboard & Notebook Mock matching Screen 7) -->
    <ImageView
        android:id="@+id/ivBackgroundMock"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_summary_gradient"
        android:alpha="0.25"
        android:visibility="gone"
        android:contentDescription="@null" />

    <!-- Top bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Hủy"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tvScreenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Tạo giao dịch"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Fullscreen scrollable container for inputs -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomActionsBar"
        android:layout_below="@+id/topBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Type Segment Selector (Expense/Income) -->
            <RadioGroup
                android:id="@+id/rgType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:checkedButton="@id/rbExpense"
                android:background="@drawable/bg_rounded_card"
                android:backgroundTint="@color/surface"
                android:padding="4dp"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/rbExpense"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:button="@null"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:text="Khoản chi"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:background="@drawable/bg_button_rounded"
                    android:backgroundTint="@color/expense_red" />

                <RadioButton
                    android:id="@+id/rbIncome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:button="@null"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:text="Khoản thu"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </RadioGroup>

            <!-- Glassmorphic Card for Amount Input -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider"
                app:cardBackgroundColor="@color/surface"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- Amount Entry EditText -->
                    <EditText
                        android:id="@+id/edtAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="center"
                        android:hint="Nhập số tiền"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:importantForAutofill="no" />

                    <!-- Dynamic VND Formatted text -->
                    <TextView
                        android:id="@+id/tvFormattedAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thêm chi tiết"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Transaction Title Input (Coffee, Food, etc.) -->
            <EditText
                android:id="@+id/edtTitle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Tên giao dịch (Ví dụ: Cà phê)"
                android:inputType="text"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <!-- Dynamic Pill Row: Wallet and Category Selectors -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Category Selector Spinner Container styled as Pill -->
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_button_rounded"
                    android:backgroundTint="@color/surface">

                    <Spinner
                        android:id="@+id/spCategory"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="12dp"
                        android:paddingEnd="36dp"
                        android:background="@null" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_arrow_down"
                        app:tint="@color/text_secondary"
                        android:clickable="false"
                        android:focusable="false"
                        android:contentDescription="@null" />
                </RelativeLayout>

                <!-- Wallet Selector Spinner Container styled as Pill -->
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_button_rounded"
                    android:backgroundTint="@color/surface">

                    <Spinner
                        android:id="@+id/spAccount"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="12dp"
                        android:background="@null" />
                </RelativeLayout>

            </LinearLayout>

            <!-- Prefilled Date Input styled as Pill -->
            <EditText
                android:id="@+id/edtDate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ngày giao dịch"
                android:focusable="false"
                android:clickable="true"
                android:gravity="center_vertical"
                android:background="@drawable/bg_button_rounded"
                android:backgroundTint="@color/surface"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:drawableStart="@android:drawable/ic_menu_today"
                android:drawablePadding="12dp"
                app:drawableTint="@color/text_secondary"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <!-- Note/Ghi Chú Input -->
            <EditText
                android:id="@+id/edtNote"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ghi chú (Tùy chọn)"
                android:inputType="text"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:layout_marginBottom="24dp"
                android:importantForAutofill="no" />

            <!-- Optional Image Attachment Section -->
            <LinearLayout
                android:id="@+id/layoutAttachmentSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:gravity="start">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ảnh đính kèm (tùy chọn)"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Add Image Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddImage"
                    style="@style/Widget.PersonalFinance.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="+ Thêm ảnh"
                    android:textColor="@color/primary"
                    app:strokeColor="@color/primary"
                    app:icon="@drawable/ic_camera"
                    app:iconTint="@color/primary"
                    android:textAllCaps="false" />

                <!-- Image Preview Area -->
                <RelativeLayout
                    android:id="@+id/layoutImagePreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:visibility="gone"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        app:cardBackgroundColor="@color/surface">

                        <ImageView
                            android:id="@+id/ivThumbnail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="Thumbnail" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Remove Button -->
                    <ImageView
                        android:id="@+id/btnRemoveImage"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_close"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/expense_red"
                        app:tint="@color/white"
                        android:padding="6dp"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:layout_margin="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Remove image" />
                </RelativeLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions Container -->
    <LinearLayout
        android:id="@+id/bottomActionsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:background="@color/background"
        android:orientation="horizontal">

        <!-- Old scan-related retake button (will only show in Scan confirmation mode) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetake"
            style="@style/Widget.PersonalFinance.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginEnd="12dp"
            android:text="Chụp lại"
            android:textColor="@color/text_secondary"
            app:strokeColor="@color/divider"
            app:icon="@drawable/ic_camera"
            app:iconTint="@color/text_secondary"
            android:visibility="gone"
            android:textAllCaps="false" />

        <!-- New clean Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.PersonalFinance.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Lưu giao dịch"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <!-- Share Button (only shows in scan confirmation mode if needed, otherwise gone) -->
        <ImageView
            android:id="@+id/btnShare"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_share"
            android:padding="12dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/surface"
            app:tint="@color/text_primary"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:contentDescription="Share" />

    </LinearLayout>

</RelativeLayout>
