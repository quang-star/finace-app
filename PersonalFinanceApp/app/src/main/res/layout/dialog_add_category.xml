<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ui_them_danh_muc_moi"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Name input -->
    <EditText
        android:id="@+id/edtCategoryName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_rounded_card"
        android:backgroundTint="@color/surface_variant"
        android:hint="@string/ui_ten_danh_muc"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:paddingHorizontal="16dp"
        android:singleLine="true"
        android:layout_marginBottom="16dp" />

    <!-- Color selection label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ui_chon_mau_sac"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="12dp" />

    <!-- Color options row -->
    <LinearLayout
        android:id="@+id/colorContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginBottom="24dp">

        <View
            android:id="@+id/colorOrange"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="#F97316"
            android:layout_marginHorizontal="6dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/colorBlue"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="#3B82F6"
            android:layout_marginHorizontal="6dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/colorGreen"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="#10B981"
            android:layout_marginHorizontal="6dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/colorIndigo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="#6366F1"
            android:layout_marginHorizontal="6dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/colorPink"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="#EC4899"
            android:layout_marginHorizontal="6dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_cancel"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ui_luu_lai"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_rounded"
            android:backgroundTint="@color/primary"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
