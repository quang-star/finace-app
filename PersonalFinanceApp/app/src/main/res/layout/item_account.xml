<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Wallet Icon Circle -->
        <View
            android:id="@+id/viewTypeColor"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/status_active"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/imgAccountIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_transaction"
            app:tint="@color/white"
            app:layout_constraintStart_toStartOf="@id/viewTypeColor"
            app:layout_constraintEnd_toEndOf="@id/viewTypeColor"
            app:layout_constraintTop_toTopOf="@id/viewTypeColor"
            app:layout_constraintBottom_toBottomOf="@id/viewTypeColor" />

        <!-- Account Details Name -->
        <LinearLayout
            android:id="@+id/layoutName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/viewTypeColor"
            app:layout_constraintEnd_toStartOf="@id/layoutBalance"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvAccountType"
            app:layout_constraintVertical_chainStyle="packed">

            <TextView
                android:id="@+id/tvAccountName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wallet"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- Orange Star Badge -->
            <TextView
                android:id="@+id/txtStarBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★"
                android:textColor="#E5C158"
                android:textSize="12sp"
                android:layout_marginStart="6dp"
                android:gravity="center" />

            <!-- 'd' Badge -->
            <TextView
                android:id="@+id/txtDefaultBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:text="d"
                android:textColor="#E5C158"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_circle"
                android:backgroundTint="#2A220F"
                android:gravity="center"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAccountType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:text="Ví điện tử"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/viewTypeColor"
            app:layout_constraintEnd_toStartOf="@id/layoutBalance"
            app:layout_constraintTop_toBottomOf="@id/layoutName"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Balance Layout and Indicator -->
        <LinearLayout
            android:id="@+id/layoutBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-271,000đ"
                android:textColor="@color/expense_red"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_down"
                android:rotation="270"
                android:layout_marginStart="8dp"
                app:tint="@color/text_secondary" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
