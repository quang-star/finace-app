<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:backgroundTint="@color/surface"
    android:padding="20dp">

    <!-- Top drag handle bar indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/divider"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Title Header -->
    <TextView
        android:id="@+id/tvRecurringTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên Giao dịch Định kỳ"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Option 1: Pause / Resume -->
    <LinearLayout
        android:id="@+id/btnPauseResume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_rounded_card"
        android:backgroundTint="@color/surface_variant"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_recurring"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/tvPauseResumeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạm dừng định kỳ"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Option 2: Edit -->
    <LinearLayout
        android:id="@+id/btnEditRecurring"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_rounded_card"
        android:backgroundTint="@color/surface_variant"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_edit_pencil"
            app:tint="@color/income_green" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chỉnh sửa định kỳ"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Option 3: Delete -->
    <LinearLayout
        android:id="@+id/btnDeleteRecurring"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_rounded_card"
        android:backgroundTint="@color/surface_variant"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            app:tint="@color/expense_red" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xóa định kỳ"
            android:textColor="@color/expense_red"
            android:textSize="14sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>

</LinearLayout>
